<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <PackageId>RP2040Sharp.TestKit</PackageId>
    <Description>Test utilities and helpers for writing unit tests against RP2040Sharp emulator firmware.</Description>
    <IsPackable>true</IsPackable>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\RP2040.Core\RP2040.Core.csproj" />
    <ProjectReference Include="..\RP2040.Peripherals\RP2040.Peripherals.csproj" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="FluentAssertions" Version="8.8.0" />
  </ItemGroup>
</Project>
